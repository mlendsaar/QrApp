<Window x:Class="QrApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QrApp"
        Title="Settings"
        Width="480"
        SizeToContent="Height"
        MinHeight="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />

        <!-- Toggle switch style for CheckBox -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Track" Width="40" Height="20" CornerRadius="10"
                                    Background="#CCCCCC" VerticalAlignment="Center">
                                <Border x:Name="Thumb" Width="16" Height="16" CornerRadius="8"
                                        Background="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.3" />
                                    </Border.Effect>
                                </Border>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#0078D4" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Segoe UI Variable" />
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"       Value="16" />
            <Setter Property="FontWeight"     Value="SemiBold" />
            <Setter Property="FontFamily"     Value="Segoe UI Variable" />
            <Setter Property="Margin"         Value="0,16,0,6" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="#F3F3F3" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <TextBlock Text="Settings"
                       FontSize="20" FontWeight="SemiBold"
                       FontFamily="Segoe UI Variable"
                       VerticalAlignment="Center" Margin="16,0" />
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16,0,16,16">

                <!-- Hotkey -->
                <TextBlock Text="Hotkey" Style="{StaticResource SectionHeader}" />
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <TextBox x:Name="HotkeyBox"
                                 Text="{Binding HotkeyPlaceholder, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Padding="8,6"
                                 FontSize="14"
                                 FontFamily="Segoe UI Variable"
                                 AutomationProperties.Name="Hotkey"
                                 PreviewMouseLeftButtonDown="HotkeyBox_MouseDown"
                                 PreviewKeyDown="HotkeyBox_KeyDown" />
                        <TextBlock Text="{Binding HotkeyConflictMessage}"
                                   Visibility="{Binding HotkeyConflictMessage, Converter={StaticResource BoolToVis}}"
                                   Foreground="#C42B1C"
                                   FontSize="12"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                    </Grid>
                </Border>

                <!-- QR Code -->
                <TextBlock Text="QR Code" Style="{StaticResource SectionHeader}" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Size" VerticalAlignment="Center"
                               FontSize="14" FontFamily="Segoe UI Variable" Margin="0,0,12,0" />
                    <Slider Grid.Column="1"
                            Minimum="200" Maximum="600" TickFrequency="50"
                            IsSnapToTickEnabled="True"
                            Value="{Binding TargetSizePx}"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="QR target size" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding TargetSizePx, StringFormat='{}{0} px'}"
                               VerticalAlignment="Center" Margin="8,0"
                               FontSize="14" FontFamily="Segoe UI Variable" />
                    <Image Grid.Column="3"
                           x:Name="QrPreviewImage"
                           Height="60" Width="60"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           AutomationProperties.Name="QR preview" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ECC Level" VerticalAlignment="Center"
                               FontSize="14" FontFamily="Segoe UI Variable" Margin="0,0,12,0" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding EccLevelOptions}"
                              SelectedItem="{Binding EccLevel}"
                              FontSize="14"
                              AutomationProperties.Name="Error correction level" />
                    <TextBlock Grid.Column="2" Text="ⓘ" FontSize="16" VerticalAlignment="Center"
                               Margin="8,0,0,0">
                        <TextBlock.ToolTip>Higher recovery = smaller data capacity. Q is a good default.</TextBlock.ToolTip>
                    </TextBlock>
                </Grid>

                <!-- Overlay -->
                <TextBlock Text="Overlay" Style="{StaticResource SectionHeader}" />
                <StackPanel Orientation="Horizontal">
                    <CheckBox Content="Auto-dismiss after"
                              IsChecked="{Binding AutoDismissEnabled}"
                              VerticalAlignment="Center"
                              FontSize="14" FontFamily="Segoe UI Variable"
                              AutomationProperties.Name="Enable auto-dismiss" />
                    <TextBox Width="40"
                             Text="{Binding AutoDismissSeconds}"
                             IsEnabled="{Binding AutoDismissEnabled}"
                             Margin="8,0"
                             Padding="4,2"
                             FontSize="14"
                             AutomationProperties.Name="Auto-dismiss seconds" />
                    <TextBlock Text="seconds" VerticalAlignment="Center"
                               FontSize="14" FontFamily="Segoe UI Variable" />
                </StackPanel>
                <CheckBox Content="Show OCR Region button in overlay"
                          IsChecked="{Binding ShowOcrButton}"
                          Margin="0,8,0,0"
                          Style="{StaticResource ToggleSwitch}"
                          AutomationProperties.Name="Show OCR Region button" />

                <!-- Startup -->
                <TextBlock Text="Startup" Style="{StaticResource SectionHeader}" />
                <CheckBox Content="Launch QrApp when Windows starts"
                          IsChecked="{Binding Autostart}"
                          FontSize="14" FontFamily="Segoe UI Variable"
                          AutomationProperties.Name="Launch at Windows startup" />

                <!-- Symbol Filter -->
                <TextBlock Text="Symbol Filter" Style="{StaticResource SectionHeader}" />
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="4">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="32" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Match"   FontSize="12" Foreground="#717171" Margin="4,2" />
                            <TextBlock Grid.Column="1" Text="Replace" FontSize="12" Foreground="#717171" Margin="4,2" />
                            <TextBlock Grid.Column="2" Text="Regex"   FontSize="12" Foreground="#717171" Margin="4,2" HorizontalAlignment="Center" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Rules}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="32" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Match, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Cascadia Mono, Consolas"
                                                 FontSize="12" Padding="3,2" Margin="2,0"
                                                 AutomationProperties.Name="Match pattern" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Replace, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Cascadia Mono, Consolas"
                                                 FontSize="12" Padding="3,2" Margin="2,0"
                                                 AutomationProperties.Name="Replacement" />
                                        <CheckBox Grid.Column="2"
                                                  IsChecked="{Binding IsRegex}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  AutomationProperties.Name="Use regex" />
                                        <Button Grid.Column="3"
                                                Content="🗑"
                                                FontSize="14"
                                                Tag="{Binding}"
                                                Click="DeleteRule_Click"
                                                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                                AutomationProperties.Name="Delete rule" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Add rule"
                                HorizontalAlignment="Left"
                                Margin="2,4"
                                Padding="6,3"
                                Command="{Binding AddRuleCommand}"
                                AutomationProperties.Name="Add filter rule" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Background="#F3F3F3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="16,0">
                <Button Content="Cancel"
                        Width="80" Height="32" Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        AutomationProperties.Name="Cancel" />
                <Button Content="Apply"
                        Width="80" Height="32"
                        Command="{Binding ApplyCommand}"
                        IsDefault="True"
                        AutomationProperties.Name="Apply settings" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
