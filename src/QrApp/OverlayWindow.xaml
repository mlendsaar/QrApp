<Window x:Class="QrApp.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QrApp"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="560" Height="300"
        MinWidth="400" MinHeight="240"
        UseLayoutRounding="True">

    <Window.Resources>
        <local:StatusLevelToVisibilityConverter x:Key="StatusVisibility" />
        <local:StatusLevelToBrushConverter      x:Key="StatusBrush" />
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}" />
    </Window.InputBindings>

    <Border CornerRadius="8"
            Background="#F3F3F3"
            BorderBrush="#E0E0E0"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.25" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="#E8E8E8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.Effect>
                    <BlurEffect Radius="0" />
                </Grid.Effect>

                <Button x:Name="OcrButton"
                        Grid.Column="0"
                        Content="⬡ OCR Region"
                        Click="OcrButton_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"
                        Padding="8,4"
                        FontSize="13"
                        FontFamily="Segoe UI Variable"
                        AutomationProperties.Name="Capture OCR region"
                        Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />

                <Button x:Name="HelpButton"
                        Grid.Column="1"
                        Content="?"
                        Click="HelpButton_Click"
                        Width="32" Height="32"
                        VerticalAlignment="Center"
                        FontSize="14"
                        AutomationProperties.Name="Show help"
                        Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                    <Button.ToolTip>Help</Button.ToolTip>
                </Button>

                <!-- Help popup -->
                <Popup x:Name="HelpPopup"
                       PlacementTarget="{Binding ElementName=HelpButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="White"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="16,12"
                            MinWidth="280">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.18" Color="#000000" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="How to use"
                                       FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI Variable"
                                       Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="1." FontSize="12" FontFamily="Segoe UI Variable" Foreground="#555" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Copy text" FontSize="12" FontFamily="Segoe UI Variable" Margin="0,0,12,3" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Ctrl+C" FontSize="12" FontFamily="Cascadia Mono, Consolas" Foreground="#444" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="2." FontSize="12" FontFamily="Segoe UI Variable" Foreground="#555" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Press hotkey" FontSize="12" FontFamily="Segoe UI Variable" Margin="0,0,12,3" />
                                <TextBlock Grid.Row="1" Grid.Column="2"
                                           Text="{Binding HotkeyLabel}"
                                           FontSize="12" FontFamily="Cascadia Mono, Consolas" Foreground="#444" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="3." FontSize="12" FontFamily="Segoe UI Variable" Foreground="#555" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Scan the QR code" FontSize="12" FontFamily="Segoe UI Variable" Margin="0,0,12,3" />
                            </Grid>
                            <Border BorderBrush="#E8E8E8" BorderThickness="0,1,0,0" Margin="0,10,0,8" />
                            <TextBlock FontSize="11" FontFamily="Segoe UI Variable" Foreground="#717171" LineHeight="18">
                                <Run>Edit the text on the left to update the QR.</Run>
                                <LineBreak />
                                <Run>Press </Run><Run FontFamily="Cascadia Mono, Consolas" Foreground="#444">Esc</Run><Run> or click outside to close.</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Popup>

                <Button Grid.Column="2"
                        Content="✕"
                        Click="CloseButton_Click"
                        Width="32" Height="32"
                        VerticalAlignment="Center"
                        FontSize="14"
                        AutomationProperties.Name="Close overlay"
                        Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- TextBox column -->
                <Grid Grid.Column="0" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <TextBox x:Name="SourceTextBox"
                                 Text="{Binding SourceText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 SpellCheck.IsEnabled="False"
                                 FontFamily="Cascadia Mono, Consolas"
                                 FontSize="13"
                                 BorderBrush="#E0E0E0"
                                 BorderThickness="1"
                                 Padding="4"
                                 AutomationProperties.Name="Captured text" />
                        <!-- Placeholder hint — overlaid, pointer-transparent -->
                        <TextBlock x:Name="PlaceholderText"
                                   Text="Selected text will appear here…"
                                   Foreground="#9D9D9D"
                                   FontFamily="Segoe UI Variable"
                                   FontSize="13"
                                   Margin="6,6,0,0"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Top"
                                   Visibility="Collapsed" />
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{Binding ByteCountText}"
                               HorizontalAlignment="Right"
                               FontSize="12"
                               Foreground="#717171"
                               Margin="0,2,0,0"
                               AutomationProperties.Name="Byte count" />
                </Grid>

                <!-- QR Image column -->
                <Border Grid.Column="1"
                        Margin="0,16,16,16"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                    <Image Source="{Binding QrImage}"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           AutomationProperties.Name="{Binding SourceText}" />
                </Border>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="2"
                    CornerRadius="0,0,8,8"
                    Background="{Binding StatusLevel, Converter={StaticResource StatusBrush}}"
                    Visibility="{Binding StatusLevel, Converter={StaticResource StatusVisibility}}">
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Margin="12,0"
                           FontSize="12"
                           FontFamily="Segoe UI Variable" />
            </Border>
        </Grid>
    </Border>
</Window>
